{
  "buildCommand": "pnpm --filter @workspace/home-tracker run build",
  "outputDirectory": "artifacts/home-tracker/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
